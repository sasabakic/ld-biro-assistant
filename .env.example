# Copy to .env (for Vite client-side) and .dev.vars (for wrangler / Pages Functions).

# --- Vite (client-side, exposed to browser) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Pages Functions (server-side, used in functions/) ---
# These mirror the VITE_ ones and add server-only secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=your_gemini_key_here
